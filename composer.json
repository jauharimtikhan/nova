{
    "name": "jtech/nova",
    "description": "Jtech NOVA Framework",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "jauhar imtikhan",
            "email": "jauhar.imtikhan@gmail.com"
        }
    ],
     "scripts": {
        "post-install-cmd": [
            "@php jtech migrate",
            "@php jtech optimize:clear",
            "@php jtech key:generate --if-missing"
        ],
        "post-update-cmd": [
            "@php jtech optimize:clear"
        ],
        "post-autoload-dump": [
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "require": {
        "jtech/novalites": "^0.0.6"
    }
}
